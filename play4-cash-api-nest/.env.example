# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/play4cash

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_here
JWT_ACCESS_TOKEN_TTL_SECS=3600
JWT_REFRESH_TOKEN_TTL_SECS=86400

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_FROM=noreply@play4cash.com
EMAIL_PASS=your_email_password_here
EMAIL_VERIFICATION_EXPIRY_MINUTES=60

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ─── Withdrawals ──────────────────────────────────────────────────────────────
PROCESSING_EXPIRY_MINUTES=30
WITHDRAWAL_VERIFICATION_EXPIRY_MINUTES=30
MIN_WITHDRAWAL=10
JOB_CRON_WITHDRAWAL_IN_PROCESSING=*/5 * * * *

# ─── CORS & WebSocket ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4200,https://your-app.com
SOCKET_ORIGIN=https://your-app.com

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated admin email addresses
ADMIN_EMAILS=admin@play4cash.com

# ─── Swagger ──────────────────────────────────────────────────────────────────
ENABLE_SWAGGER=true
SWAGGER_PASSWORD=your_swagger_password_here
