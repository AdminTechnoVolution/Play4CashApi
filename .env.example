PORT=3000
ENABLE_SWAGGER=true
SWAGGER_PASSWORD=your_secure_swagger_password
ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.com
SOCKET_ORIGIN=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/play4cash
REDIS_URI=redis://localhost:6379
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ACCESS_TOKEN_TTL_SECS=3600
JWT_REFRESH_TOKEN_TTL_SECS=86400
JWT_ISSUER=play4cash-api
JWT_AUDIENCE=play4cash-clients
AUTH_REFRESH_COOKIE_NAME=p4c_refresh
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_SECURE=false
EMAIL_SERVICE=gmail
EMAIL_FROM=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_VERIFICATION_EXPIRY_MINUTES=60
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
PROCESSING_EXPIRY_MINUTES=30
WITHDRAWAL_VERIFICATION_EXPIRY_MINUTES=30
MIN_WITHDRAWAL=10
JOB_CRON_WITHDRAWAL_IN_PROCESSING="*/5 * * * *"
GOOGLE_CLIENT_ID=web_client
ADMIN_EMAILS=admin@example.com
GATEWAY_INTERNAL_SECRET=
GATEWAY_TRUST_HEADER_NAME=x-gateway-internal
# Optional: UNO match target when the catalog Game row has no `uno_match_target` (50–500 after clamp).
UNO_MATCH_TARGET=

TRUSTED_GATEWAY_IPS=
PWA_MIN_VERSION=
PWA_STATS_SAMPLE_RATE=0.1
PWA_STATS_RETENTION_DAYS=31
DEPOSIT_DAILY_LIMIT=10000
WITHDRAWAL_DAILY_LIMIT=10000
